{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wuerde/mitmach-einreichung",
  "title": "Mitmach-Einreichung",
  "category": "wuerde",
  "description": "Formular zum Einreichen von Mitmach-Beiträgen. Erstellt ausstehende Einträge zur Freigabe.",
  "keywords": ["mitmach", "einreichung", "formular", "beitrag"],
  "textdomain": "wuerde-unantastbar",
  "supports": { "html": false, "align": false },
  "attributes": {
    "sectionBeitrag":          { "type": "string", "default": "Dein Beitrag" },
    "sectionOrt":              { "type": "string", "default": "Ort" },
    "sectionKontakt":          { "type": "string", "default": "Deine Kontaktdaten" },
    "labelName":               { "type": "string", "default": "Name" },
    "labelEmail":              { "type": "string", "default": "E-Mail-Adresse" },
    "labelTitel":              { "type": "string", "default": "Titel" },
    "labelBeschreibung":       { "type": "string", "default": "Beschreibung" },
    "labelKategorie":          { "type": "string", "default": "Kategorie(n)" },
    "labelKurzbeschreibung":   { "type": "string", "default": "Kurzbeschreibung des Angebots (freiwillig)" },
    "labelTelefon":            { "type": "string", "default": "Telefonnummer (freiwillig)" },
    "labelAdresse":            { "type": "string", "default": "Adresse" },
    "labelOrt":                { "type": "string", "default": "Ort (freiwillig)" },
    "labelEmailPublic":        { "type": "string", "default": "Ich bin einverstanden, dass meine E-Mail-Adresse auf der Beitragsseite veröffentlicht wird." },
    "labelTelefonPublic":      { "type": "string", "default": "Ich bin einverstanden, dass meine Telefonnummer auf der Beitragsseite veröffentlicht wird." },
    "placeholderTitel":        { "type": "string", "default": "z. B. Kunstprojekt im Stadtmuseum" },
    "placeholderBeschreibung": { "type": "string", "default": "Was habt ihr gemacht? Was war besonders?" },
    "placeholderKurzbeschreibung": { "type": "string", "default": "Max. zwei Sätze, z. B. für die Übersicht" },
    "placeholderTelefon":      { "type": "string", "default": "z. B. 0151 23456789" },
    "placeholderAdresse":      { "type": "string", "default": "z. B. Marktplatz 1, München" },
    "placeholderOrt":          { "type": "string", "default": "z. B. München" },
    "btnAdresse":              { "type": "string", "default": "Suchen" },
    "btnSubmit":               { "type": "string", "default": "Beitrag einreichen" },
    "karteToggle":             { "type": "string", "default": "Ort auf Karte auswählen (optional)" },
    "dateiHinweisVor":         { "type": "string", "default": "Fotos und Dokumente bitte per E-Mail an" },
    "dateiHinweisNach":        { "type": "string", "default": "senden — nach dem Absenden erhältst du eine Referenznummer." }
  },
  "render": "file:./render.php",
  "viewScript": "file:./view.js",
  "viewStyle": "file:./view.css",
  "editorScript": "file:./editor.js"
}
