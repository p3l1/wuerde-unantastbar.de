{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wuerde/grundidee-banner",
  "title": "Grundidee-Banner",
  "category": "wuerde",
  "description": "Farbiger Banner mit Krone-Wasserzeichen, Titel, Text und CTA-Button.",
  "keywords": ["banner", "highlight", "cta", "würde"],
  "textdomain": "wuerde-unantastbar",
  "attributes": {
    "title": {
      "type": "string",
      "default": "ein Zeichen setzen für Menschenwürde und Demokratie."
    },
    "buttonText": {
      "type": "string",
      "default": "Jetzt mitmachen"
    },
    "buttonUrl": {
      "type": "string",
      "default": "/mach-mit/"
    },
    "color": {
      "type": "string",
      "default": "teal",
      "enum": ["teal", "yellow"]
    }
  },
  "supports": {
    "html": false,
    "align": false
  },
  "render": "file:./render.php",
  "editorScript": "file:./editor.js",
  "editorStyle": "file:./editor.css"
}
